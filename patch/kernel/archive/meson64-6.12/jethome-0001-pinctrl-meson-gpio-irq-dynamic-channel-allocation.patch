From 024936d8b6fb67a4704ed6d6d7a32fe45e532301 Mon Sep 17 00:00:00 2001
From: Viacheslav Bocharov <v@baodeep.com>
Date: Thu, 11 Jun 2026 12:07:56 +0300
Subject: [PATCH] pinctrl: meson: add GPIO interrupt support with dynamic
 channel allocation

Meson GPIO banks have no per-pin interrupt logic; a separate
meson-gpio-intc block muxes a small number of channels (8 on most
SoCs) onto GIC SPIs, each channel watching exactly one pad.

Previous attempts (Brunet 2016 4/9, Kallweit 2017 v6, Lin Shenghuan
2020) either created the parent mapping from .to_irq - permanently
leaking one of the 8 channels per touched pin since nothing ever
calls irq_dispose_mapping - or allocated it from .irq_set_type,
which runs under desc->lock and must not sleep.

Register a gpiolib irqchip instead and tie the scarce channel to the
life time of the requested interrupt:

 - .irq_request_resources (sleepable, called once per request_irq)
   creates the fwspec mapping in the gpio-intc domain, claiming a
   channel, and installs a chained handler on the parent virq;
 - .irq_release_resources removes the handler and disposes the
   mapping, returning the channel to the pool;
 - .to_irq stays the gpiolib default: it only creates a cheap mapping
   in the gpiochip's own domain and consumes no channel.

So up to 8 lines can be watched concurrently and any number of
different lines may be used over time (sysfs/libgpiod), with a clean
-ENOSPC instead of a permanently exhausted controller.

IRQ_TYPE_EDGE_BOTH is taken natively where the gpio-intc supports it
(SM1, S4, ...). On older SoCs (AXG, GXL, ...) it can optionally be
emulated (PINCTRL_MESON_GPIO_IRQ_EDGE_BOTH_EMU) by re-arming the
single channel for the opposite edge on every interrupt; a net level
change is never lost, only complete pulses shorter than the re-arm
latency can be missed.

The pr_* diagnostics in the request/release paths are intentional
for field debugging on JetHome devices.

Co-authored-by: Claude Fable 5 <noreply@anthropic.com>
Signed-off-by: Viacheslav Bocharov <v@baodeep.com>
---
 drivers/pinctrl/meson/Kconfig         |  14 ++
 drivers/pinctrl/meson/pinctrl-meson.c | 317 ++++++++++++++++++++++++++
 drivers/pinctrl/meson/pinctrl-meson.h |  19 ++
 3 files changed, 350 insertions(+)

diff --git a/drivers/pinctrl/meson/Kconfig b/drivers/pinctrl/meson/Kconfig
index cc397896762c..8df23869bf65 100644
--- a/drivers/pinctrl/meson/Kconfig
+++ b/drivers/pinctrl/meson/Kconfig
@@ -8,11 +8,25 @@ menuconfig PINCTRL_MESON
 	select PINCONF
 	select GENERIC_PINCONF
 	select GPIOLIB
+	select GPIOLIB_IRQCHIP
 	select OF_GPIO
 	select REGMAP_MMIO
 
 if PINCTRL_MESON
 
+config PINCTRL_MESON_GPIO_IRQ_EDGE_BOTH_EMU
+	bool "Emulate both-edge GPIO interrupts by toggling the polarity"
+	help
+	  Most Amlogic GPIO interrupt controllers cannot follow both
+	  edges of a line with a single channel. With this option an
+	  IRQ_TYPE_EDGE_BOTH request on such a controller is emulated
+	  by re-arming the channel for the opposite edge on every
+	  interrupt. A net level change is never lost, but complete
+	  pulses shorter than the re-arm latency (a few microseconds,
+	  up to hundreds of microseconds under load) may be missed.
+	  SoCs with native both-edge support (SM1, S4, ...) do not use
+	  the emulation. If unsure, say N.
+
 config PINCTRL_MESON8
 	bool "Meson 8 SoC pinctrl driver"
 	depends on ARM
diff --git a/drivers/pinctrl/meson/pinctrl-meson.c b/drivers/pinctrl/meson/pinctrl-meson.c
index 253a0cc57e39..f49926c8ea85 100644
--- a/drivers/pinctrl/meson/pinctrl-meson.c
+++ b/drivers/pinctrl/meson/pinctrl-meson.c
@@ -40,7 +40,11 @@
 #include <linux/device.h>
 #include <linux/gpio/driver.h>
 #include <linux/init.h>
+#include <linux/interrupt.h>
 #include <linux/io.h>
+#include <linux/irq.h>
+#include <linux/irqchip/chained_irq.h>
+#include <linux/irqdomain.h>
 #include <linux/of.h>
 #include <linux/of_address.h>
 #include <linux/pinctrl/pinconf-generic.h>
@@ -602,6 +606,281 @@ static int meson_gpio_get(struct gpio_chip *chip, unsigned gpio)
 	return !!(val & BIT(bit));
 }
 
+/*
+ * GPIO interrupts
+ *
+ * Meson GPIO banks have no per-pin interrupt logic. A separate
+ * "amlogic,meson-gpio-intc" block muxes a small number of channels
+ * (8 on most SoCs) onto GIC SPIs, each channel watching exactly one
+ * pad at a time.
+ *
+ * The scarce channels are recycled instead of being leaked on first
+ * use: a channel is claimed when an interrupt is requested on a line
+ * (irq_request_resources) and released again when the last handler
+ * is freed (irq_release_resources).
+ */
+
+/*
+ * Bound for the re-arm loop of the both-edge emulation, which runs in
+ * hard interrupt context. One pass is enough for a quiet line, two or
+ * three cover a contact bounce hitting the reprogramming window; eight
+ * caps the worst case at roughly ten microseconds. A line still
+ * flipping after that oscillates faster than the emulation can follow
+ * and its intermediate events are lost anyway, so giving up is safe
+ * (see the bail-out comment in meson_gpio_irq_emu_rearm()) and better
+ * than spinning in hard irq context indefinitely.
+ */
+#define MESON_GPIO_IRQ_EMU_LOOPS	8
+
+static int meson_gpio_irq_hwirq(struct meson_pinctrl *pc, unsigned int offset)
+{
+	const struct meson_bank *bank;
+	int hwirq;
+
+	if (meson_get_bank(pc, offset, &bank))
+		return -EINVAL;
+
+	if (bank->irq_first < 0)
+		return -EINVAL;
+
+	hwirq = offset - bank->first + bank->irq_first;
+	if (hwirq > bank->irq_last)
+		return -EINVAL;
+
+	return hwirq;
+}
+
+static void meson_gpio_irq_init_valid_mask(struct gpio_chip *chip,
+					   unsigned long *valid_mask,
+					   unsigned int ngpios)
+{
+	struct meson_pinctrl *pc = gpiochip_get_data(chip);
+	unsigned int offset;
+
+	for (offset = 0; offset < ngpios; offset++)
+		if (meson_gpio_irq_hwirq(pc, offset) < 0)
+			clear_bit(offset, valid_mask);
+}
+
+static struct meson_gpio_irq_line *meson_gpio_irq_to_line(struct irq_data *data)
+{
+	struct gpio_chip *chip = irq_data_get_irq_chip_data(data);
+	struct meson_pinctrl *pc = gpiochip_get_data(chip);
+
+	return &pc->irq_lines[irqd_to_hwirq(data)];
+}
+
+/*
+ * Reprogramming the gpio-intc filter (edge mode, polarity inversion,
+ * pad mux) makes the signal seen by its edge detector jump, which
+ * latches a phantom edge as pending in the GIC. Drop it after every
+ * reprogramming step. Real edges cleared by accident are recovered by
+ * the level re-check of the emulation loop (the callers' transitions
+ * are level-checked too), so a net level change is still never lost.
+ */
+static void meson_gpio_irq_clear_pending(struct meson_gpio_irq_line *line)
+{
+	irq_set_irqchip_state(line->parent_virq, IRQCHIP_STATE_PENDING,
+			      false);
+}
+
+/*
+ * Arm the single gpio-intc channel for the edge opposite to the
+ * current line level. If the line flips while the filter is being
+ * reprogrammed, the missed transition is synthesized and the channel
+ * re-armed, so a net level change is never lost; only complete pulses
+ * shorter than the re-arm latency can be missed.
+ */
+static void meson_gpio_irq_emu_rearm(struct meson_gpio_irq_line *line,
+				     bool dispatch)
+{
+	struct gpio_chip *chip = &line->pc->chip;
+	int level, loops = MESON_GPIO_IRQ_EMU_LOOPS;
+
+	do {
+		level = meson_gpio_get(chip, line->offset);
+		irq_set_irq_type(line->parent_virq,
+				 level ? IRQ_TYPE_EDGE_FALLING :
+					 IRQ_TYPE_EDGE_RISING);
+		meson_gpio_irq_clear_pending(line);
+
+		if (meson_gpio_get(chip, line->offset) == level)
+			return;
+
+		if (dispatch)
+			generic_handle_domain_irq(chip->irq.domain,
+						  line->offset);
+	} while (--loops);
+
+	/*
+	 * Bailing out is safe: the channel is never masked here and
+	 * stays armed for the edge leading away from the last sampled
+	 * level. If the line settled on that level, this is exactly the
+	 * arming for the next real transition. If it flipped once more
+	 * after the sample, the flip is the very edge the channel is
+	 * armed for, so it is already latched as pending and the
+	 * handler will run again and re-synchronize. Only events
+	 * within the oscillation burst itself are lost.
+	 */
+	dev_warn_ratelimited(line->pc->dev,
+			     "pin[%u] oscillates faster than both-edge emulation\n",
+			     line->offset);
+}
+
+static void meson_gpio_irq_handler(struct irq_desc *desc)
+{
+	struct meson_gpio_irq_line *line = irq_desc_get_handler_data(desc);
+	struct irq_chip *irqchip = irq_desc_get_chip(desc);
+	struct gpio_chip *chip = &line->pc->chip;
+
+	chained_irq_enter(irqchip, desc);
+
+	generic_handle_domain_irq(chip->irq.domain, line->offset);
+
+	if (line->both_emu)
+		meson_gpio_irq_emu_rearm(line, true);
+
+	chained_irq_exit(irqchip, desc);
+}
+
+static void meson_gpio_irq_mask(struct irq_data *data)
+{
+	struct meson_gpio_irq_line *line = meson_gpio_irq_to_line(data);
+
+	disable_irq_nosync(line->parent_virq);
+}
+
+static void meson_gpio_irq_unmask(struct irq_data *data)
+{
+	struct meson_gpio_irq_line *line = meson_gpio_irq_to_line(data);
+
+	enable_irq(line->parent_virq);
+}
+
+static int meson_gpio_irq_set_type(struct irq_data *data, unsigned int type)
+{
+	struct meson_gpio_irq_line *line = meson_gpio_irq_to_line(data);
+	int ret;
+
+	line->both_emu = false;
+
+	if ((type & IRQ_TYPE_SENSE_MASK) == IRQ_TYPE_EDGE_BOTH &&
+	    IS_ENABLED(CONFIG_PINCTRL_MESON_GPIO_IRQ_EDGE_BOTH_EMU)) {
+		struct irq_data *pd = irq_get_irq_data(line->parent_virq);
+
+		/*
+		 * Probe native both-edge support with a direct call to
+		 * the parent chip: a plain irq_set_irq_type() would log
+		 * a genirq error on every controller without it. The
+		 * parent virq belongs exclusively to this line, nothing
+		 * else can race with the probe.
+		 */
+		if (pd->chip->irq_set_type(pd, IRQ_TYPE_EDGE_BOTH)) {
+			line->both_emu = true;
+			meson_gpio_irq_emu_rearm(line, false);
+			pr_info("gpio irq both-edge emulation: pin[%u]\n",
+				line->offset);
+			return 0;
+		}
+	}
+
+	ret = irq_set_irq_type(line->parent_virq, type);
+	if (!ret)
+		meson_gpio_irq_clear_pending(line);
+
+	return ret;
+}
+
+static int meson_gpio_irq_request_resources(struct irq_data *data)
+{
+	struct gpio_chip *chip = irq_data_get_irq_chip_data(data);
+	struct meson_pinctrl *pc = gpiochip_get_data(chip);
+	unsigned int offset = irqd_to_hwirq(data);
+	struct meson_gpio_irq_line *line = &pc->irq_lines[offset];
+	struct irq_fwspec fwspec;
+	int hwirq, virq, ret;
+
+	hwirq = meson_gpio_irq_hwirq(pc, offset);
+	if (hwirq < 0)
+		return hwirq;
+
+	ret = gpiochip_reqres_irq(chip, offset);
+	if (ret)
+		return ret;
+
+	fwspec.fwnode = of_fwnode_handle(pc->of_irq);
+	fwspec.param_count = 2;
+	fwspec.param[0] = hwirq;
+	fwspec.param[1] = IRQ_TYPE_EDGE_RISING;
+
+	virq = irq_create_fwspec_mapping(&fwspec);
+	if (virq <= 0) {
+		dev_warn(pc->dev,
+			 "no free gpio-intc channel for pin[%u] (hwirq 0x%X)\n",
+			 offset, hwirq);
+		gpiochip_relres_irq(chip, offset);
+		return virq < 0 ? virq : -ENOSPC;
+	}
+
+	line->pc = pc;
+	line->offset = offset;
+	line->parent_virq = virq;
+	line->both_emu = false;
+
+	/* benign filter setting until irq_set_type programs the real one */
+	irq_set_irq_type(virq, IRQ_TYPE_EDGE_RISING);
+	/*
+	 * Routing the pad through the channel mux and reprogramming a
+	 * filter left armed by a previous user of the channel latch a
+	 * phantom edge in the GIC. Drop it BEFORE the chained handler
+	 * is installed: installing unmasks the parent, and a phantom
+	 * delivered at that moment would stick as IRQS_PENDING on the
+	 * still subscriber-less child and be replayed into the first
+	 * request_irq()'s handler.
+	 */
+	meson_gpio_irq_clear_pending(line);
+	irq_set_chained_handler_and_data(virq, meson_gpio_irq_handler, line);
+	/* balance the depth so that the first child unmask enables it */
+	disable_irq(virq);
+	meson_gpio_irq_clear_pending(line);
+
+	pr_info("gpio irq setup: hwirq: 0x%X parent virq: %d pin[%u]\n",
+		hwirq, virq, offset);
+
+	return 0;
+}
+
+static void meson_gpio_irq_release_resources(struct irq_data *data)
+{
+	struct gpio_chip *chip = irq_data_get_irq_chip_data(data);
+	struct meson_pinctrl *pc = gpiochip_get_data(chip);
+	unsigned int offset = irqd_to_hwirq(data);
+	struct meson_gpio_irq_line *line = &pc->irq_lines[offset];
+
+	if (line->parent_virq > 0) {
+		irq_set_chained_handler_and_data(line->parent_virq, NULL,
+						 NULL);
+		irq_dispose_mapping(line->parent_virq);
+		pr_info("gpio irq released: parent virq: %d pin[%u]\n",
+			line->parent_virq, offset);
+	}
+
+	line->parent_virq = 0;
+	line->both_emu = false;
+
+	gpiochip_relres_irq(chip, offset);
+}
+
+static const struct irq_chip meson_gpio_irq_chip = {
+	.name			= "meson-gpio",
+	.irq_mask		= meson_gpio_irq_mask,
+	.irq_unmask		= meson_gpio_irq_unmask,
+	.irq_set_type		= meson_gpio_irq_set_type,
+	.irq_request_resources	= meson_gpio_irq_request_resources,
+	.irq_release_resources	= meson_gpio_irq_release_resources,
+	.flags			= IRQCHIP_IMMUTABLE,
+};
+
 static int meson_gpiolib_register(struct meson_pinctrl *pc)
 {
 	int ret;
@@ -621,6 +900,21 @@ static int meson_gpiolib_register(struct meson_pinctrl *pc)
 	pc->chip.ngpio = pc->data->num_pins;
 	pc->chip.can_sleep = false;
 
+	if (pc->of_irq) {
+		struct gpio_irq_chip *girq = &pc->chip.irq;
+
+		pc->irq_lines = devm_kcalloc(pc->dev, pc->data->num_pins,
+					     sizeof(*pc->irq_lines),
+					     GFP_KERNEL);
+		if (!pc->irq_lines)
+			return -ENOMEM;
+
+		gpio_irq_chip_set_chip(girq, &meson_gpio_irq_chip);
+		girq->init_valid_mask = meson_gpio_irq_init_valid_mask;
+		girq->default_type = IRQ_TYPE_NONE;
+		girq->handler = handle_simple_irq;
+	}
+
 	ret = gpiochip_add_data(&pc->chip, pc);
 	if (ret) {
 		dev_err(pc->dev, "can't add gpio chip %s\n",
@@ -662,10 +956,16 @@ static struct regmap *meson_map_resource(struct meson_pinctrl *pc,
 	return devm_regmap_init_mmio(pc->dev, base, &meson_regmap_config);
 }
 
+static void meson_pinctrl_put_node(void *data)
+{
+	of_node_put(data);
+}
+
 static int meson_pinctrl_parse_dt(struct meson_pinctrl *pc)
 {
 	struct device_node *gpio_np;
 	unsigned int chips;
+	int ret;
 
 	chips = gpiochip_node_count(pc->dev);
 	if (!chips) {
@@ -680,6 +980,23 @@ static int meson_pinctrl_parse_dt(struct meson_pinctrl *pc)
 	pc->fwnode = gpiochip_node_get_first(pc->dev);
 	gpio_np = to_of_node(pc->fwnode);
 
+	/*
+	 * The GPIO interrupt controller is shared by all pinctrl
+	 * instances (AO and periphs) and uses one hwirq number space
+	 * covering every pad, so looking up the first node is correct
+	 * for each instance.
+	 */
+	pc->of_irq = of_find_compatible_node(NULL, NULL,
+					     "amlogic,meson-gpio-intc");
+	if (pc->of_irq) {
+		ret = devm_add_action_or_reset(pc->dev, meson_pinctrl_put_node,
+					       pc->of_irq);
+		if (ret)
+			return ret;
+	} else {
+		dev_info(pc->dev, "no gpio-intc node, gpio irqs not available\n");
+	}
+
 	pc->reg_mux = meson_map_resource(pc, gpio_np, "mux");
 	if (IS_ERR_OR_NULL(pc->reg_mux)) {
 		dev_err(pc->dev, "mux registers not found\n");
diff --git a/drivers/pinctrl/meson/pinctrl-meson.h b/drivers/pinctrl/meson/pinctrl-meson.h
index 7883ea31a001..e5d8ace828bd 100644
--- a/drivers/pinctrl/meson/pinctrl-meson.h
+++ b/drivers/pinctrl/meson/pinctrl-meson.h
@@ -122,6 +122,23 @@ struct meson_pinctrl_data {
 	int (*parse_dt)(struct meson_pinctrl *pc);
 };
 
+struct meson_pinctrl;
+
+/**
+ * struct meson_gpio_irq_line - state of one GPIO line used as interrupt
+ *
+ * @pc:		the pinctrl instance the line belongs to
+ * @offset:	gpio offset of the line within the chip
+ * @parent_virq: virq of the dynamically mapped gpio-intc channel
+ * @both_emu:	both-edge trigger is emulated by polarity toggling
+ */
+struct meson_gpio_irq_line {
+	struct meson_pinctrl *pc;
+	unsigned int offset;
+	int parent_virq;
+	bool both_emu;
+};
+
 struct meson_pinctrl {
 	struct device *dev;
 	struct pinctrl_dev *pcdev;
@@ -134,6 +151,8 @@ struct meson_pinctrl {
 	struct regmap *reg_ds;
 	struct gpio_chip chip;
 	struct fwnode_handle *fwnode;
+	struct device_node *of_irq;
+	struct meson_gpio_irq_line *irq_lines;
 };
 
